{
  "name": "backcountry-desktop",
  "version": "1.1.2",
  "description": "Backcountry Pathfinders — application desktop d'acquisition (évaluateur de pistes de brousse pour MSFS 2024, via SimConnect)",
  "main": "src/main/main.js",
  "author": "Cyril MILANI",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "publish": "electron-builder --publish always"
  },
  "keywords": [
    "electron",
    "msfs",
    "simconnect",
    "backcountry",
    "bush-flying",
    "vfr"
  ],
  "dependencies": {
    "electron-updater": "^6.3.9",
    "extract-zip": "^2.0.1",
    "geomagnetism": "^0.2.0",
    "node-simconnect": "^4.2.0"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "me.sixk.pathfinders.desktop",
    "productName": "Backcountry Pathfinders",
    "copyright": "Copyright © 2026 Cyril MILANI — GPL-3.0-or-later",
    "artifactName": "Backcountry-Pathfinders-Setup-${version}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!tools/**",
      "!dist/**",
      "!config.json",
      "!config.example.json",
      "!**/*.log",
      "!README.md"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Backcountry Pathfinders",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "brackets-acrobat",
      "repo": "backcountry-desktop"
    }
  }
}
